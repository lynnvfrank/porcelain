# ─────────────────────────────────────────────────────────────────────────────
#  D:\Rebirth\ .gitignore
#  Comments explain *why* something is ignored so you can change your mind later.
# ─────────────────────────────────────────────────────────────────────────────

# ── Nested git repos (each has its own .git/, manage from inside) ────────────
# Lynn's gateway — pull from her GitHub by cd'ing in: `cd claudia-gateway && git pull`
claudia-gateway/

# Old archive — kept on disk for reference, not part of this repo's history
Previously Claudia Core/

# ── Voice journal / audio data ───────────────────────────────────────────────
# Recordings, transcripts, conversations — personal + huge.
# Scripts (record.py, receiver.py) are NOT ignored — only the data.
Moto X/claudia_motoxaudio_data/

# Receiver state files (regenerated on each run)
Moto X/*.log
Moto X/receiver_log.md
Moto X/claudia_record_log.md
Moto X/__pycache__/

# Ingest state (rebuilt automatically)
ingest_state.json

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments — recreate locally with `pip install -r requirements.txt`
.venv/
.venv-transcribe/
venv/
env/
ENV/

# Test / coverage artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Secrets & local config ───────────────────────────────────────────────────
# Never commit API keys, tokens, or session secrets
.env
.env.local
.env.*.local
*.key
*.pem
secrets.yaml
tokens.yaml

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# Continue extension config (per-machine)
.continue/

# ── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# ── Build / cache artifacts ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
.next/
.cache/
*.tsbuildinfo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Local databases (regeneratable) ──────────────────────────────────────────
# Qdrant data, bifrost data — these live inside claudia-gateway/ which is
# already ignored, but keep these patterns in case you move things.
*.sqlite
*.sqlite-journal
*.db-shm
*.db-wal
config.db
logs.db
metrics.sqlite

# ── PWA build outputs (regenerated by build_web_app.py) ──────────────────────
# Comment this out if you'd rather commit the bundled JS for reproducibility.
# pwa/static/web_app.js

# ── Misc ─────────────────────────────────────────────────────────────────────
# Claude Code session scratch
.claude/
