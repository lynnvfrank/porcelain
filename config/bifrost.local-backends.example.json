{
  "config_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "./config.db"
    }
  },
  "client": {
    "drop_excess_requests": false
  },
  "providers": {
    "openai": {
      "name": "openai",
      "keys": [
        {
          "name": "local-vllm",
          "value": "env.LOCAL_VLLM_API_KEY",
          "models": []
        },
        {
          "name": "local-llamacpp",
          "value": "env.LOCAL_LLAMACPP_API_KEY",
          "models": []
        }
      ],
      "network_config": {
        "base_url": "http://127.0.0.1:8000/v1",
        "default_request_timeout_in_seconds": 60
      }
    }
  }
}
